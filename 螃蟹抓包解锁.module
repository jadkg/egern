#!name=螃蟹抓包解锁
#!desc=螃蟹抓包解锁

[Script]
storm = type=http-response, pattern=^https?:\/\/api\.x-storm\.com\/app\/(user-profile|share-code\/get)\/$, script-path=https://raw.githubusercontent.com/wf021325/qx/master/js/storm.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% *.x-storm.com
