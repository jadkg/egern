#!name=京东比价
#!desc=无需第三方软件获取Cookie、历史价格会显示在京东商品“详情”页。

[Script]
# >京东比价
bijia = type=http-response, pattern=^https?:\/\/in\.m\.jd\.com\/product\/graphext\/\d+\.html, script-path=https://raw.githubusercontent.com/WeiGiegie/666/main/bijia.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% in.m.jd.com
